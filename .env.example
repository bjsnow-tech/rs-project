# Copy this file to .env and fill in your values.
# The CLI loads .env automatically if python-dotenv is installed.

# Required for all price data fetching (Polygon.io API key).
POLYGON_API_KEY=your_polygon_key_here

# Required for --finviz-url universe scans.
# Find your token in Finviz Elite → Account → API (auth= param in export URLs).
FINVIZ_AUTH_TOKEN=your_token_here

# Default Finviz Elite export URL used when --finviz-url is not passed.
# Use {token} as a placeholder and it will be filled from FINVIZ_AUTH_TOKEN.
FINVIZ_URL=https://elite.finviz.com/export.ashx?v=111&f=...&auth={token}
